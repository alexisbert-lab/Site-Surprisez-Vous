rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Catalogue produits — lecture publique, écriture admin uniquement
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Catalogues clients — lecture pro/admin, écriture admin
    match /catalogues/{catalogueId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Catégories — lecture publique, écriture admin
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Groupes produit-catégorie — lecture publique, écriture admin
    match /product-groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Déclinaisons — lecture publique, écriture admin
    match /declinations/{decId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Commandes ERP — lecture par le client concerné, admin full access
    match /commandes/{commandeId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        string(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.client_id) == string(resource.data.clt_id) ||
        string(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.client_erp_id) == string(resource.data.clt_id)
      );
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Commandes web — lecture/écriture pour l'utilisateur concerné, admin full access
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.clientEmail == request.auth.token.email ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Clients — lecture propre (par email), écriture admin uniquement
    match /clients/{clientId} {
      allow read: if request.auth != null && (
        resource.data.email == request.auth.token.email ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Demandes pro — création publique (authentifié), lecture/update admin
    match /pro-requests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Profils utilisateurs — lecture propre, création propre, mise à jour admin
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow create: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Événements — lecture publique, écriture admin
    match /evenements/{evtId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Marques — lecture publique, écriture admin
    match /marques/{marqueId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Marques-produits mapping — lecture publique, écriture admin
    match /product-marques/{docId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Tarifs — lecture pro et admin, écriture admin uniquement
    match /tarifs/{tarifId} {
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'pro'];
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      match /lignes/{ligneId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'pro'];
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    // Ruptures — admin uniquement
    match /ruptures/{ruptureId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Groupes de contact — admin uniquement
    match /groupes-contact/{groupeId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Marketing — lecture publique, écriture admin
    match /marketing/{itemId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Articles/Actualités — lecture publique, écriture admin
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Contenu pages — lecture publique, écriture admin
    match /contenu-pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Contenu pages (éditeur visuel) — lecture publique, écriture admin
    match /page-content/{pageId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Settings — lecture publique, écriture admin
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Codes statistiques — lecture publique, écriture admin
    match /stat-categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
