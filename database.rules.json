{
  "rules": {
    "notifications": {
      "admin": {
        // Lecture + suppression : admins uniquement (custom claim posé par setAdminClaim)
        ".read": "auth != null && auth.token.admin === true",
        // Écriture : tout utilisateur authentifié (createOrder est appelé côté client)
        ".write": "auth != null",
        "$notifId": {
          ".validate": "newData.hasChildren(['type', 'label', 'at'])"
        }
      },
      "clients": {
        "$uid": {
          // Lecture : uniquement le client lui-même (auth.uid === son propre UID)
          ".read": "auth != null && auth.uid === $uid",
          // Écriture : le client lui-même (markRead, clear) ou un admin (pushClientOrderNotif côté CF)
          ".write": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
          "$notifId": {
            ".validate": "newData.hasChildren(['orderId', 'label', 'statut', 'at'])"
          }
        }
      }
    },
    // Tout le reste est fermé par défaut
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
