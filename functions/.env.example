# Configuration des Cloud Functions Firebase
# Copier ce fichier en .env et remplir les valeurs
# Ne pas committer .env (déjà dans .gitignore)

# SMTP — envoi des emails de commande
SMTP_HOST=mail.surprisez-vous.fr
SMTP_PORT=587
SMTP_USER=contact@surprisez-vous.fr
SMTP_PASS=votre_mot_de_passe

# URL du serveur Next.js en production (pour les appels depuis les Cloud Functions)
NEXTJS_BASE_URL=

# URL de la Cloud Function de cache
CACHE_CF_URL=

# Secret partagé avec Next.js — doit être identique au CACHE_SECRET de .env.local
CACHE_SECRET=
