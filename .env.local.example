# Firebase Client SDK — récupérer depuis la console Firebase
# https://console.firebase.google.com/project/site-surprisez-vous/settings/general
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# measurementId — Firebase console > Paramètres > Vos applications (format G-XXXXXXXXXX)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Instagram
NEXT_PUBLIC_INSTAGRAM_FUNCTION_URL=
NEXT_PUBLIC_INSTAGRAM_HANDLE=

# Seed (compte admin pour npm run seed)
SEED_EMAIL=
SEED_PASSWORD=

# Cache Cloud Function
CACHE_CF_URL=
NEXT_PUBLIC_CACHE_CF_URL=
# Secret partagé avec Cloud Functions pour sécuriser /api/cache/* et /api/revalidate
CACHE_SECRET=
